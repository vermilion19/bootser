SERVER_PORT=8091
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics
TELEMETRYHUB_SIMULATOR_RUNTIME_PUBLISHED_MESSAGE_BUFFER_ENABLED=false
TELEMETRYHUB_SIMULATOR_PUBLISHER_MODE=MQTT
TELEMETRYHUB_SIMULATOR_PUBLISHER_BRIDGE_ENABLED=false
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_ENABLED=true
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_REAL_CLIENT_ENABLED=true
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_BROKER_URI=tcp://mqtt-broker:1883
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_CLIENT_ID=telemetryhub-device-simulator
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_QOS=0
TELEMETRYHUB_SIMULATOR_PUBLISHER_MQTT_RETAIN=false
