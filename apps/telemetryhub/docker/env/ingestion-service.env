SERVER_PORT=8092
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,prometheus,metrics
SPRING_KAFKA_BOOTSTRAP_SERVERS=host.docker.internal:9092
TELEMETRYHUB_INGESTION_RUNTIME_RECENT_EVENT_BUFFER_ENABLED=false
TELEMETRYHUB_INGESTION_MQTT_ENABLED=true
TELEMETRYHUB_INGESTION_MQTT_REAL_CLIENT_ENABLED=true
TELEMETRYHUB_INGESTION_MQTT_BROKER_URI=tcp://mqtt-broker:1883
TELEMETRYHUB_INGESTION_MQTT_CLIENT_ID=telemetryhub-ingestion-service
TELEMETRYHUB_INGESTION_PUBLISHER_MODE=KAFKA
TELEMETRYHUB_INGESTION_PUBLISHER_KAFKA_ENABLED=true
TELEMETRYHUB_INGESTION_PUBLISHER_KAFKA_RAW_TOPIC=telemetryhub.raw-events
TELEMETRYHUB_INGESTION_PUBLISHER_KAFKA_KEY_STRATEGY=DEVICE_ID
