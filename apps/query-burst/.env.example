# ==============================================
# Query Burst - Environment Variables
#
# 사용법:
# 1. 이 파일을 복사: cp .env.example .env
# 2. .env 파일의 값들을 실제 값으로 수정
# 3. IDE 또는 터미널에서 환경변수 로드 후 실행
#
# IntelliJ: Run Configuration > Environment variables 또는 EnvFile 플러그인
# Terminal: export $(cat .env | xargs) && ./gradlew :apps:query-burst:bootRun
# ==============================================

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=query_burst
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis (optional, local profile uses localhost:6379 by default)
# REDIS_HOST=localhost
# REDIS_PORT=6379