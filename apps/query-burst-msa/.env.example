# ==============================================
# Query Burst MSA - Environment Variables
#
# 사용법:
# 1. 이 파일을 복사: cp .env.example .env
# 2. .env 파일의 값들을 실제 값으로 수정
# 3. 로컬 실행 또는 docker compose 실행
#
# 로컬 실행:
# export $(cat .env | xargs) && ./gradlew :apps:query-burst-msa:{service}:bootRun
#
# Docker Compose 실행:
# docker compose --env-file .env -f apps/query-burst-msa/docker-compose.yml up --build
# ==============================================

# ------------------------------------------------------------------------------
# PostgreSQL account
# compose와 앱이 함께 사용합니다.
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# App database connection
DB_HOST=booster-postgres
DB_PORT=5432
DB_USERNAME=wer2wer
DB_PASSWORD=gozldwhwRk

# Database Names (각 서비스별 DB)
# DB_NAME 환경변수는 서비스별로 기본값이 다름
# - member-service: query_burst_member
# - catalog-service: query_burst_catalog
# - order-service: query_burst_order
# - analytics-service: query_burst_analytics

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=booster-redis
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# Kafka
# ------------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=booster-kafka:9092

# ------------------------------------------------------------------------------
# Inter-service URL
# ------------------------------------------------------------------------------
CATALOG_SERVICE_BASE_URL=http://catalog-service:18113

# ------------------------------------------------------------------------------
# Observability
# 로컬 observability stack을 따로 띄우지 않으면 기본값 그대로 둬도 됩니다.
# ------------------------------------------------------------------------------
TEMPO_ZIPKIN_ENDPOINT=http://tempo:9411/api/v2/spans
LOKI_URL=http://loki:3100/loki/api/v1/push
