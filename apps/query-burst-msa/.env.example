# ==============================================
# Query Burst MSA - Environment Variables
#
# 사용법:
# 1. 이 파일을 복사: cp .env.example .env
# 2. .env 파일의 값들을 실제 값으로 수정
# 3. IDE 또는 터미널에서 환경변수 로드 후 실행
#
# IntelliJ: Run Configuration > Environment variables 또는 EnvFile 플러그인
# Terminal: export $(cat .env | xargs) && ./gradlew :apps:query-burst-msa:{service}:bootRun
# ==============================================

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Database Names (각 서비스별 DB)
# DB_NAME 환경변수는 서비스별로 기본값이 다름
# - member-service: query_burst_member
# - catalog-service: query_burst_catalog
# - order-service: query_burst_order
# - analytics-service: query_burst_analytics

# Redis (ranking-service에서 사용)
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka (order-service, analytics-service, ranking-service에서 사용)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Observability
TEMPO_ZIPKIN_ENDPOINT=http://localhost:9411/api/v2/spans
LOKI_URL=http://localhost:3100/loki/api/v1/push
